#!/usr/bin/env bash
# spec-first SessionStart hook
# Injects methodology reminder + project KNOWLEDGE.md at every session start.
# Installed to .claude/spec-first/ by install.sh

set -euo pipefail

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

# ── Core reminder (brief — full rules are in your project constitution) ──────

context="<spec-first-active>
<IMPORTANT>
spec-first methodology is active for this project.

BEFORE writing ANY implementation code:
1. Check: does a spec exist in specs/ for this change?
2. If NO → write one FIRST. Bug fix = 5 min. Feature = 15 min. Emergency = fix first, spec after.
3. If YES → read it before implementing. Handle every S1 error state in code.

AFTER writing spec, run Scope Routing: count S1 + S3 → Autonomous / Review / Required.

This is not optional. Code without a spec uses the AI's default probability — which is wrong 65% of the time on error states and integrations.
</IMPORTANT>"

# ── Inject KNOWLEDGE.md if it exists ────────────────────────────────────────

KNOWLEDGE_FILE="$(pwd)/KNOWLEDGE.md"
if [ -f "$KNOWLEDGE_FILE" ] && [ -s "$KNOWLEDGE_FILE" ]; then
  knowledge=$(cat "$KNOWLEDGE_FILE")
  context+="

<project-knowledge>
Patterns and lessons discovered in this codebase — read before writing any code:

${knowledge}
</project-knowledge>"
fi

# ── Inject session state if it exists (continuity from previous session) ───

SESSION_STATE="$(pwd)/.claude/session-state.md"
if [ -f "$SESSION_STATE" ] && [ -s "$SESSION_STATE" ]; then
  state=$(cat "$SESSION_STATE")
  context+="

<previous-session>
State from last session — continue from here:

${state}
</previous-session>"
fi

context+="
</spec-first-active>"

escaped=$(escape_for_json "$context")

# ── Output platform-appropriate JSON ─────────────────────────────────────────
# Claude Code sets CLAUDE_PLUGIN_ROOT; Cursor sets CURSOR_PLUGIN_ROOT.
# Other platforms fall back to additional_context.

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{"additional_context": "%s"}\n' "$escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{"hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": "%s"}}\n' "$escaped"
else
  printf '{"additional_context": "%s"}\n' "$escaped"
fi

exit 0
